# Phase 1.4 — Adaptive sync priority by distance.
#
# Currently all entities in streaming_distance sync at the same cadence. We add
# tiered priority so close entities get more frequent updates than far ones.
#
# Target files:
#   code/components/citizen-server-impl/src/state/ServerGameState.cpp
#     - functions: OnClonesSync, ProcessClonesSync, ResortClones

# === Priority tiers (per pair: entity ↔ viewer) ===
#
# distance < 30 m   : 60 Hz  (cars you're racing alongside)
# 30 m <= d < 100 m : 30 Hz  (cars on the same street)
# 100 m <= d < 200 m: 10 Hz  (cars in your neighborhood)
# 200 m <= d < 300 m:  3 Hz  (distant traffic)
# d >= 300 m        : event-only (creation/destruction)
#
# Implementation: per-(entity, viewer) pair we track lastSyncTime; on each
# server tick we recompute distance and only enqueue the snapshot if
# (now - lastSyncTime) >= 1000ms / tierHz.

