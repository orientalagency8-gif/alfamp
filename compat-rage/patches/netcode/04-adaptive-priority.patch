# === Convars (live tuning) ===
#
#   sv_alfa_priority_tier1_distance     default 30
#   sv_alfa_priority_tier1_hz           default 60
#   sv_alfa_priority_tier2_distance     default 100
#   sv_alfa_priority_tier2_hz           default 30
#   sv_alfa_priority_tier3_distance     default 200
#   sv_alfa_priority_tier3_hz           default 10
#   sv_alfa_priority_tier4_distance     default 300
#   sv_alfa_priority_tier4_hz           default 3
#
# Tune these per-server: race-server might want tier1 distance smaller
# (cars are crowded), open-world freeroam might extend it (you're sparse).

# === Bandwidth model ===
#
# Stock CFX 30 Hz × 30 entities = 900 snapshots/sec per viewer
# This patch: 1×60 + 5×30 + 10×10 + 10×3 + 4×0  ≈ 340 snapshots/sec
# = 62% reduction in network load, while CLOSE entities sync 2× faster.

# === Quick-win without patch ===
#
# Existing convar already gives part of this:
#   set onesync_distanceCullVehicles true   # binary cull, no tiers
#
# This patch is the proper graded version.
