# Normalize line endings on commit to LF, regardless of the contributor's OS.
* text=auto eol=lf

# Native Windows tooling needs CRLF
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.sln       text eol=crlf
*.csproj    text eol=crlf

# Treat known-binary as binary so we don't get diff noise
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.dll       binary
*.exe       binary
*.so        binary
*.dylib     binary
*.zip       binary
*.tar.xz    binary
*.tar.gz    binary
*.7z        binary
*.msi       binary
